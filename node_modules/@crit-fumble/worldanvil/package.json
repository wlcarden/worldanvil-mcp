{
  "name": "@crit-fumble/worldanvil",
  "version": "3.1.0",
  "description": "Client SDK for World Anvil API - types and HTTP client for worldbuilding integration",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/crit-fumble/core.crit-fumble.com.git",
    "directory": "packages/worldanvil"
  },
  "keywords": [
    "crit-fumble",
    "worldanvil",
    "world-anvil",
    "worldbuilding",
    "ttrpg",
    "api-client"
  ],
  "author": "Crit-Fumble",
  "license": "MIT",
  "engines": {
    "node": ">=20.19.0"
  }
}
